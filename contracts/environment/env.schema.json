{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "APP_NAME": {
      "type": "string"
    },
    "ENV": {
      "type": "string",
      "enum": ["dev", "prod"]
    },
    "DEBUG": {
      "type": "boolean"
    },
    "DATABASE_URL": {
      "type": "string",
      "format": "uri"
    }
  },
  "required": ["APP_NAME", "ENV", "DEBUG", "DATABASE_URL"],
  "additionalProperties": false
}